---
import Layout from '../layouts/Layout.astro';
---

<Layout title="À propos — Mat.enseigne">

  <!-- ═══════════════════════════════════════ -->
  <!-- SECTION 1 — PAGE HERO                  -->
  <!-- ═══════════════════════════════════════ -->
  <section class="ahero">
    <img
      src="/abtushero.jpeg"
      alt=""
      aria-hidden="true"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0.3;z-index:0;"
    />
    <div class="ahero__inner reveal">

      <!-- Gold accent line -->
      <div class="ahero__accent-line" aria-hidden="true"></div>

      <!-- Label -->
      <div class="section-label section-label--centered">
        <span class="section-label__line"></span>
        <span class="section-label__text">À propos de nous</span>
        <span class="section-label__line"></span>
      </div>

      <h1 class="ahero__title">L'enseigne, c'est notre métier depuis 2008</h1>

      <p class="ahero__sub">
        Fabrication et pose d'enseignes, façades et signalétique pour tous types de
        commerces — Paris &amp; Île-de-France.
      </p>

    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- SECTION 2 — WHO WE ARE                 -->
  <!-- ═══════════════════════════════════════ -->
  <section class="about-who">
    <div class="about-who__accent" aria-hidden="true"></div>
    <div class="about-who__grid reveal">

      <!-- Left: text -->
      <div class="about-who__text">

        <div class="section-label">
          <span class="section-label__line"></span>
          <span class="section-label__text">Qui sommes-nous</span>
        </div>

        <h2 class="about-who__title">Experts en enseignes &amp; façades commerciales</h2>

        <p class="about-who__para">
          Depuis 2008, Mat.enseigne fabrique et pose des enseignes lumineuses, stores bannes,
          marquages adhésifs et façades pour tous types de commerces en Île-de-France.
          Coiffeurs, restaurateurs, boutiques, cabinets — nous travaillons pour tous ceux
          qui veulent que leur commerce soit remarqué.
        </p>

        <p class="about-who__para">
          Notre atelier de fabrication nous permet de tout contrôler — de la conception
          à la pose. Pas de sous-traitance, pas d'intermédiaire. Vous avez un seul
          interlocuteur du début à la fin de votre projet.
        </p>

      </div>

      <!-- Right: photo -->
      <div class="about-who__img-wrap">
        <img
          src="/abtus.jpeg"
          alt="Atelier Mat.enseigne"
          style="width:100%; height:100%; object-fit:cover; display:block;"
        />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- SECTION 3 — MISSION                    -->
  <!-- ═══════════════════════════════════════ -->
  <section class="about-mission">
    <div class="about-mission__inner reveal">

      <!-- Corner accents -->
      <span class="about-mission__corner about-mission__corner--tl" aria-hidden="true"></span>
      <span class="about-mission__corner about-mission__corner--br" aria-hidden="true"></span>

      <div class="section-label section-label--centered">
        <span class="section-label__line"></span>
        <span class="section-label__text">Notre engagement vers l'excellence</span>
        <span class="section-label__line"></span>
      </div>

      <h2 class="about-mission__title">Notre Mission</h2>

      <p class="about-mission__body">
        Fabriquer des enseignes et des façades qui durent, qui se remarquent et qui
        reflètent l'identité de chaque commerce. Nous nous engageons à livrer un travail
        soigné, dans les délais, avec un seul objectif : que votre vitrine travaille pour vous.
      </p>

    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- SECTION 4 — VALUES                     -->
  <!-- ═══════════════════════════════════════ -->
  <section class="about-values">

    <div class="about-values__header reveal">
      <div class="section-label">
        <span class="section-label__line"></span>
        <span class="section-label__text">Nos valeurs fondamentales</span>
      </div>
      <h2 class="about-values__title">Les principes de Mat.enseigne</h2>
    </div>

    <div class="about-values__grid-wrap reveal">
      <div class="about-values__grid">

        <div class="about-values__card">
          <p class="about-values__num">01</p>
          <h3 class="about-values__card-title">Fabrication locale</h3>
          <p class="about-values__card-body">
            Tout est fabriqué dans notre atelier en Île-de-France. Aucune sous-traitance,
            un contrôle total de la qualité.
          </p>
        </div>

        <div class="about-values__card">
          <p class="about-values__num">02</p>
          <h3 class="about-values__card-title">Transparence</h3>
          <p class="about-values__card-body">
            Devis clair, délais respectés, zéro mauvaise surprise. Vous savez toujours
            où en est votre projet.
          </p>
        </div>

        <div class="about-values__card about-values__card--last">
          <p class="about-values__num">03</p>
          <h3 class="about-values__card-title">Sur mesure</h3>
          <p class="about-values__card-body">
            Chaque projet est unique. Nous adaptons chaque réalisation à votre commerce,
            votre budget, votre identité.
          </p>
        </div>

      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- SECTION 5 — FAQ                        -->
  <!-- ═══════════════════════════════════════ -->
  <section class="about-faq">
    <div class="about-faq__inner">

      <div class="reveal">
        <div class="section-label section-label--centered">
          <span class="section-label__line"></span>
          <span class="section-label__text">Questions fréquentes</span>
          <span class="section-label__line"></span>
        </div>
        <h2 class="about-faq__title">Tout savoir sur nos services</h2>
      </div>

      <div class="faq-list reveal">

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            <span>Quels types de commerces servez-vous ?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            <p class="faq-answer__text">
              Nous travaillons avec tous types de commerces — coiffeurs, restaurants,
              kebabs, pharmacies, boutiques de mode, salons de beauté, garages, bureaux
              et bien plus. Si vous avez une vitrine, nous pouvons l'améliorer.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            <span>Comment obtenir un devis ?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            <p class="faq-answer__text">
              Appelez-nous directement au 06 05 89 44 11 ou envoyez-nous un message via
              la page contact. Nous nous déplaçons gratuitement pour voir votre commerce
              et vous remettre un devis personnalisé sous 24h.
              {/* TODO: update phone number */}
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            <span>Intervenez-vous partout en Île-de-France ?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            <p class="faq-answer__text">
              Oui, nous intervenons sur Paris et l'ensemble de l'Île-de-France —
              Seine-et-Marne, Yvelines, Essonne, Hauts-de-Seine, Seine-Saint-Denis,
              Val-de-Marne et Val-d'Oise.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


</Layout>

<style>
  /* ── Scroll reveal ──────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Shared: section label ──────────────── */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .section-label--centered {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  /* Gold dot before the first line */
  .section-label::before {
    content: '';
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.8;
    flex-shrink: 0;
  }
  .section-label__line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
    flex-shrink: 0;
  }
  .section-label__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--gold);
    white-space: nowrap;
  }

  /* ── Section 1: Hero ────────────────────── */
  .ahero {
    position: relative;
    overflow: hidden;
    background: var(--navy);
    padding: 10rem 4rem 6rem;
    text-align: center;
  }
  .ahero__inner {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin: 0 auto;
  }
  .ahero__accent-line {
    width: 80px;
    height: 1px;
    background: var(--gold);
    opacity: 0.6;
    margin: 0 auto 1rem;
  }
  .ahero__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }
  .ahero__sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Section 2: Who we are ──────────────── */
  .about-who {
    position: relative;
    background: var(--bg);
    padding: 6rem 4rem;
  }
  .about-who__accent {
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    opacity: 0.4;
    pointer-events: none;
  }
  .about-who__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 72rem;
    margin: 0 auto;
  }
  .about-who__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 2.5vw, 2.4rem);
    color: var(--navy);
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }
  .about-who__para {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.75;
    margin: 0 0 1rem;
  }
  .about-who__para:last-child { margin-bottom: 0; }
  .about-who__img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  /* ── Section 3: Mission ─────────────────── */
  .about-mission {
    background: var(--navy);
    padding: 6rem 4rem;
    text-align: center;
  }
  .about-mission__inner {
    position: relative;
    max-width: 40rem;
    margin: 0 auto;
    padding: 2rem;
  }
  .about-mission__corner {
    position: absolute;
    pointer-events: none;
    opacity: 0.5;
  }
  .about-mission__corner--tl {
    top: 0;
    left: 0;
    width: 40px;
    height: 40px;
    border-top: 1px solid var(--gold);
    border-left: 1px solid var(--gold);
  }
  .about-mission__corner--br {
    bottom: 0;
    right: 0;
    width: 40px;
    height: 40px;
    border-bottom: 1px solid var(--gold);
    border-right: 1px solid var(--gold);
  }
  .about-mission__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    color: #ffffff;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }
  .about-mission__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.75;
    margin: 0;
  }

  /* ── Section 4: Values ──────────────────── */
  .about-values {
    position: relative;
    background: #ffffff;
    padding: 6rem 4rem;
  }
  .about-values::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    opacity: 0.3;
    pointer-events: none;
  }
  .about-values__header {
    max-width: 32rem;
    margin: 0 0 3rem;
  }
  .about-values__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--navy);
    line-height: 1.2;
    margin: 0;
  }
  .about-values__grid-wrap {
    background: rgba(26, 26, 46, 0.08);
  }
  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }
  .about-values__card {
    background: #ffffff;
    padding: 2.5rem;
    border-right: 1px solid rgba(26, 26, 46, 0.08);
  }
  .about-values__card--last {
    border-right: none;
  }
  .about-values__num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 2rem;
    color: rgba(201, 168, 76, 0.2);
    margin: 0 0 1rem;
    line-height: 1;
  }
  .about-values__card-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--navy);
    margin: 0 0 0.75rem;
  }
  .about-values__card-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Section 5: FAQ ─────────────────────── */
  .about-faq {
    background: var(--bg);
    padding: 6rem 4rem;
  }
  .about-faq__inner {
    max-width: 48rem;
    margin: 0 auto;
  }
  .about-faq__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--navy);
    text-align: center;
    margin: 0 0 3rem;
  }
  .faq-list {
    border-top: 1px solid rgba(26, 26, 46, 0.1);
  }
  .faq-item {
    border-bottom: 1px solid rgba(26, 26, 46, 0.1);
    border-left: 2px solid transparent;
    padding-left: 0;
    transition: border-left-color 0.3s ease, padding-left 0.3s ease;
  }
  .faq-item.open {
    border-left-color: var(--gold);
    padding-left: 1rem;
  }
  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .faq-question span:first-child {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: var(--navy);
  }
  .faq-toggle {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 1.5rem;
    color: var(--gold);
    flex-shrink: 0;
    line-height: 1;
    transition: transform 0.3s ease;
    display: block;
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 200px;
  }
  .faq-item.open .faq-toggle {
    transform: rotate(45deg);
  }
  .faq-answer__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.75;
    padding: 0 0 1.5rem;
    margin: 0;
  }


  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 767px) {
    .ahero {
      padding: 8rem 1.5rem 4rem;
    }

    .about-who {
      padding: 4rem 1.5rem;
    }
    .about-who__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-mission {
      padding: 4rem 1.5rem;
    }

    .about-values {
      padding: 4rem 1.5rem;
    }
    .about-values__header {
      margin-bottom: 2rem;
    }
    .about-values__grid {
      grid-template-columns: 1fr;
    }
    .about-values__card {
      border-right: none;
      border-bottom: 1px solid rgba(26, 26, 46, 0.08);
    }
    .about-values__card--last {
      border-bottom: none;
    }

    .about-faq {
      padding: 4rem 1.5rem;
    }

  }
</style>

<script>
  // ── Accordion ──────────────────────────────
  document.querySelectorAll('.faq-item').forEach(item => {
    const btn = item.querySelector('.faq-question');
    btn?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── Scroll reveal ──────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
