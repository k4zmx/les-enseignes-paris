---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Les Enseignes">

  <!-- CALL BAR -->
  <div class="call-bar">
    <div class="call-bar__inner">
      <span class="call-bar__segment md-only">Devis gratuit sous 24h</span>
      <span class="call-bar__sep md-only"></span>
      <a href="tel:+33123456789" class="call-bar__phone">☎ 01 23 45 67 89</a>
      <span class="call-bar__sep md-only"></span>
      <span class="call-bar__segment md-only">Paris &amp; Île-de-France</span>
    </div>
  </div>

  <!-- NAVBAR -->
  <nav id="navbar" class="navbar">
    <div class="navbar__inner">

      <!-- Logo -->
      <a href="/" class="navbar__logo">
        Les Enseignes<span class="navbar__dot"></span>
      </a>

      <!-- Nav links -->
      <div class="navbar__links">
        <a href="#services" class="navbar__link">Services</a>
        <a href="#avis"     class="navbar__link">Avis clients</a>
        <a href="tel:+33123456789" class="navbar__cta">Appeler</a>
      </div>

      <!-- Mobile: CTA + hamburger -->
      <div class="navbar__mobile-right">
        <a href="tel:+33123456789" class="navbar__cta navbar__cta--mobile">Appeler</a>
        <button
          class="hamburger"
          id="hamburger"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
        >
          <span class="hamburger__line"></span>
          <span class="hamburger__line"></span>
          <span class="hamburger__line"></span>
        </button>
      </div>

    </div>
  </nav>

  <!-- MOBILE MENU PANEL -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav">
      <a href="#services" class="mobile-menu__link">Services</a>
      <a href="#avis"     class="mobile-menu__link">Avis clients</a>
    </nav>
  </div>

  <!-- HERO -->
  <section
    class="hero"
    style="background-image: linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px); background-size: 60px 60px;"
  >

    <!-- LEFT: Text column -->
    <div class="hero__text">

      <!-- Eyebrow -->
      <div class="hero__eyebrow fade-up" style="animation-delay: 0.1s;">
        <span class="hero__eyebrow-text">Façades &amp; Signalétique commerciale</span>
        <span class="hero__eyebrow-line"></span>
      </div>

      <!-- Diptych headline -->
      <div class="hero__diptych">

        <!-- Block A — negative truth -->
        <div class="fade-up" style="animation-delay: 0.25s;">
          <p class="hero__block-label hero__block-label--red">Ce que vous perdez</p>
          <p class="hero__headline hero__headline--grey">
            Une façade négligée = un client
            <strong class="hero__headline-word--red"> perdu</strong>
          </p>
        </div>

        <!-- Gold divider -->
        <div class="hero__divider fade-up" style="animation-delay: 0.4s;">
          <span class="hero__divider-dot"></span>
          <span class="hero__divider-line"></span>
        </div>

        <!-- Block B — positive truth -->
        <div class="fade-up" style="animation-delay: 0.45s;">
          <p class="hero__block-label hero__block-label--gold">Ce que vous gagnez</p>
          <p class="hero__headline hero__headline--navy">
            Une façade soignée = une affaire qui
            <span class="hero__headline-word--gold"> inspire confiance</span>
          </p>
        </div>

      </div>

      <!-- Subtext -->
      <p class="hero__subtext fade-up" style="animation-delay: 0.6s;">
        Depuis 2008, nous fabriquons et posons des enseignes et façades qui transforment
        l'image de votre commerce — parce que votre vitrine, c'est votre premier discours.
      </p>

      <!-- CTA row -->
      <div class="hero__cta-row fade-up" style="animation-delay: 0.75s;">
        <a href="#contact" class="hero__cta-primary">
          Demander un devis gratuit
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="display:inline;vertical-align:middle;margin-left:8px;">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/services" class="hero__cta-secondary">Voir nos réalisations</a>
      </div>

    </div>

    <!-- RIGHT: Before/After visual -->
    <div class="hero__visual">

      <!-- Before panel -->
      <div class="hero__panel hero__panel--before">
        <img
          src="https://images.unsplash.com/photo-1604719312566-8912e9227c6a?w=800"
          alt="Façade avant rénovation"
          class="hero__panel-img"
        />
        <span class="hero__panel-label hero__panel-label--before">Avant</span>
      </div>

      <!-- Gold diagonal rule -->
      <div class="hero__diagonal-rule"></div>

      <!-- After panel -->
      <div class="hero__panel hero__panel--after">
        <img
          src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800"
          alt="Façade après rénovation"
          class="hero__panel-img"
        />
        <span class="hero__panel-label hero__panel-label--after">Après</span>
      </div>

    </div>

  </section>

  <!-- WHY US -->
  <section id="why" class="why">

    <!-- Decorative circles -->
    <div class="why__circle why__circle--outer" aria-hidden="true"></div>
    <div class="why__circle why__circle--inner" aria-hidden="true"></div>

    <!-- Section header -->
    <div class="why__header">

      <div class="why__header-left">
        <div class="why__label">
          <span class="why__label-line"></span>
          <span class="why__label-text">Pourquoi nous choisir</span>
        </div>
        <h2 class="why__title">
          L'image de votre commerce est notre métier depuis 2008
        </h2>
      </div>

      <div class="why__header-right">
        <p class="why__intro">
          Chaque enseigne que nous fabriquons est pensée pour durer et pour parler —
          à vos clients, à votre quartier, à votre identité. Nous ne posons pas des
          panneaux. Nous construisons des premières impressions.
        </p>
      </div>

    </div>

    <!-- Three-item grid -->
    <div class="why__grid">

      <div class="why__item">
        <p class="why__item-number">01</p>
        <h3 class="why__item-title">Fabrication sur mesure</h3>
        <p class="why__item-body">
          Chaque projet est unique. Nous concevons et fabriquons vos enseignes dans
          notre atelier — aucun élément standard, aucun compromis.
        </p>
      </div>

      <div class="why__item">
        <p class="why__item-number">02</p>
        <h3 class="why__item-title">Pose professionnelle</h3>
        <p class="why__item-body">
          Notre équipe intervient sur toute l'Île-de-France. Pose soignée, délais
          respectés, zéro mauvaise surprise le jour de l'installation.
        </p>
      </div>

      <div class="why__item">
        <p class="why__item-number">03</p>
        <h3 class="why__item-title">Interlocuteur unique</h3>
        <p class="why__item-body">
          Du premier rendez-vous à la pose finale, vous avez un seul contact. Pas de
          sous-traitance, pas de transmission de dossier. Vous savez toujours où en
          est votre projet.
        </p>
      </div>

    </div>

  </section>

  <!-- SERVICES -->
  <section id="services" class="svc">

    <!-- Header -->
    <div class="svc__header">
      <div class="svc__label">
        <span class="svc__label-line"></span>
        <span class="svc__label-text">Nos services</span>
      </div>
      <h2 class="svc__title">Ce que nous fabriquons pour vous</h2>
    </div>

    <!-- Cards grid -->
    <div class="svc__grid-wrap">
      <div class="svc__grid">

        <!-- Card 1 — Enseignes lumineuses -->
        <div class="svc__card">
          <!-- Default state -->
          <div class="svc__card-default">
            <div class="svc__icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 7 7c0 3.5-2 6-4 7.5V18H9v-1.5C7 15 5 12.5 5 9a7 7 0 0 1 7-7z"/>
              </svg>
            </div>
            <h3 class="svc__card-title">Enseignes lumineuses</h3>
            <p class="svc__card-body">LED, néon, caisson lumineux — visibles de jour comme de nuit.</p>
          </div>
          <!-- Hover image reveal -->
          <div class="svc__card-reveal">
            <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800" alt="" aria-hidden="true" class="svc__card-img" />
            <div class="svc__card-overlay"></div>
            <div class="svc__card-bottom-line"></div>
            <div class="svc__card-hover-text">
              <h3 class="svc__card-hover-title">Enseignes lumineuses</h3>
              <p class="svc__card-hover-tag">Lumière &amp; impact visuel</p>
            </div>
          </div>
        </div>

        <!-- Card 2 — Façades & Habillage -->
        <div class="svc__card">
          <div class="svc__card-default">
            <div class="svc__icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <h3 class="svc__card-title">Façades &amp; Habillage</h3>
            <p class="svc__card-body">Bardage, covering, peinture — une identité visuelle forte pour votre devanture.</p>
          </div>
          <div class="svc__card-reveal">
            <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800" alt="" aria-hidden="true" class="svc__card-img" />
            <div class="svc__card-overlay"></div>
            <div class="svc__card-bottom-line"></div>
            <div class="svc__card-hover-text">
              <h3 class="svc__card-hover-title">Façades &amp; Habillage</h3>
              <p class="svc__card-hover-tag">Votre vitrine, réinventée</p>
            </div>
          </div>
        </div>

        <!-- Card 3 — Lettres & Signalétique -->
        <div class="svc__card">
          <div class="svc__card-default">
            <div class="svc__icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 7V4h16v3M9 20h6M12 4v16"/>
              </svg>
            </div>
            <h3 class="svc__card-title">Lettres &amp; Signalétique</h3>
            <p class="svc__card-body">Lettres découpées, totems, plaques — chaque détail renforce votre image.</p>
          </div>
          <div class="svc__card-reveal">
            <img src="https://images.unsplash.com/photo-1586769852836-bc069f19e1b6?w=800" alt="" aria-hidden="true" class="svc__card-img" />
            <div class="svc__card-overlay"></div>
            <div class="svc__card-bottom-line"></div>
            <div class="svc__card-hover-text">
              <h3 class="svc__card-hover-title">Lettres &amp; Signalétique</h3>
              <p class="svc__card-hover-tag">Précision &amp; caractère</p>
            </div>
          </div>
        </div>

        <!-- Card 4 — Stores & Marquises -->
        <div class="svc__card">
          <div class="svc__card-default">
            <div class="svc__icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 7h18v4a6 6 0 0 1-6 6H9a6 6 0 0 1-6-6V7z"/>
                <line x1="3" y1="7" x2="21" y2="7"/>
                <line x1="8" y1="17" x2="8" y2="21"/>
                <line x1="16" y1="17" x2="16" y2="21"/>
              </svg>
            </div>
            <h3 class="svc__card-title">Stores &amp; Marquises</h3>
            <p class="svc__card-body">Stores bannes, marquises sur mesure — style et protection pour votre commerce.</p>
          </div>
          <div class="svc__card-reveal">
            <img src="https://images.unsplash.com/photo-1519642918688-7e43b19245d8?w=800" alt="" aria-hidden="true" class="svc__card-img" />
            <div class="svc__card-overlay"></div>
            <div class="svc__card-bottom-line"></div>
            <div class="svc__card-hover-text">
              <h3 class="svc__card-hover-title">Stores &amp; Marquises</h3>
              <p class="svc__card-hover-tag">Élégance &amp; protection</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </section>

  <!-- TARIFS -->
  <section id="tarifs" class="tarifs">
    <div class="tarifs__grid">

      <!-- LEFT: Sticky intro -->
      <div class="tarifs__intro">
        <div class="tarifs__label">
          <span class="tarifs__label-line"></span>
          <span class="tarifs__label-text">Tarifs</span>
        </div>
        <h2 class="tarifs__title">Des tarifs clairs, sans mauvaise surprise</h2>
        <p class="tarifs__desc">
          Chaque devis est gratuit et personnalisé.
          Les fourchettes ci-contre vous donnent une idée du budget
          à prévoir selon le type d'intervention.
        </p>
        <div class="tarifs__note">
          💬 Votre projet est unique — contactez-nous pour un devis sur mesure
          adapté à votre commerce.
        </div>
        <a href="tel:+33123456789" class="tarifs__cta">
          Demander un devis gratuit →
        </a>
      </div>

      <!-- RIGHT: Price list -->
      <div class="tarifs__list">

        <!-- TODO: update with real client pricing -->
        <div class="tarifs__row">
          <div class="tarifs__row-left">
            <p class="tarifs__row-title">Enseigne lumineuse LED</p>
            <p class="tarifs__row-sub">Fabrication + pose incluse</p>
          </div>
          <div class="tarifs__row-right">
            <p class="tarifs__price">800 € – 2 500 €</p>
            <p class="tarifs__unit">selon dimensions</p>
          </div>
        </div>

        <!-- TODO: update with real client pricing -->
        <div class="tarifs__row">
          <div class="tarifs__row-left">
            <p class="tarifs__row-title">Caisson lumineux</p>
            <p class="tarifs__row-sub">Sur mesure, toutes tailles</p>
          </div>
          <div class="tarifs__row-right">
            <p class="tarifs__price">1 200 € – 4 000 €</p>
            <p class="tarifs__unit">fourni et posé</p>
          </div>
        </div>

        <!-- TODO: update with real client pricing -->
        <div class="tarifs__row">
          <div class="tarifs__row-left">
            <p class="tarifs__row-title">Lettres découpées</p>
            <p class="tarifs__row-sub">Alu, inox ou PVC, rétroéclairées</p>
          </div>
          <div class="tarifs__row-right">
            <p class="tarifs__price">600 € – 3 000 €</p>
            <p class="tarifs__unit">selon matière et linéaire</p>
          </div>
        </div>

        <!-- TODO: update with real client pricing -->
        <div class="tarifs__row">
          <div class="tarifs__row-left">
            <p class="tarifs__row-title">Habillage de façade</p>
            <p class="tarifs__row-sub">Covering, peinture ou bardage</p>
          </div>
          <div class="tarifs__row-right">
            <p class="tarifs__price">Sur devis</p>
            <p class="tarifs__unit">projet unique</p>
          </div>
        </div>

        <!-- TODO: update with real client pricing -->
        <div class="tarifs__row tarifs__row--last">
          <div class="tarifs__row-left">
            <p class="tarifs__row-title">Store banne sur mesure</p>
            <p class="tarifs__row-sub">Pose et motorisation incluses</p>
          </div>
          <div class="tarifs__row-right">
            <p class="tarifs__price">900 € – 2 800 €</p>
            <p class="tarifs__unit">selon largeur</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- AVIS -->
  <section id="avis" class="avis">

    <!-- Header -->
    <div class="avis__header">

      <div class="avis__header-left">
        <div class="avis__label">
          <span class="avis__label-line"></span>
          <span class="avis__label-text">Avis clients</span>
        </div>
        <h2 class="avis__title">Ce que disent nos clients</h2>
      </div>

      <!-- Google rating badge -->
      <!-- TODO: update with real rating and count -->
      <div class="avis__badge">
        <svg width="20" height="20" viewBox="0 0 24 24" aria-label="Google" role="img">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <span class="avis__badge-divider"></span>
        <div>
          <p class="avis__badge-score">4,9 / 5</p>
          <p class="avis__badge-count">32 avis Google</p>
        </div>
      </div>

    </div>

    <!-- Reviews grid -->
    <div class="avis__grid-wrap">
      <div class="avis__grid">

        <!-- TODO: replace with real Google reviews -->
        <div class="avis__card">
          <div class="avis__stars" aria-label="5 étoiles">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="avis__text">
            "Travail exceptionnel du début à la fin. Notre nouvelle enseigne lumineuse a
            complètement transformé la visibilité de notre boutique. Les clients nous
            disent qu'ils nous remarquent maintenant depuis l'autre bout de la rue."
          </p>
          <div class="avis__author">
            <div class="avis__avatar" aria-hidden="true">M</div>
            <div>
              <p class="avis__name">Marie-Claire B.</p>
              <p class="avis__meta">Propriétaire — Boutique de mode, Paris 11e</p>
            </div>
          </div>
        </div>

        <!-- TODO: replace with real Google reviews -->
        <div class="avis__card">
          <div class="avis__stars" aria-label="5 étoiles">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="avis__text">
            "Devis clair, délais respectés, résultat impeccable. L'équipe a su comprendre
            exactement ce que je voulais pour la façade de mon restaurant. Je recommande
            sans hésiter à tous les commerçants."
          </p>
          <div class="avis__author">
            <div class="avis__avatar" aria-hidden="true">K</div>
            <div>
              <p class="avis__name">Karim M.</p>
              <p class="avis__meta">Gérant — Restaurant Le Safran, Paris 15e</p>
            </div>
          </div>
        </div>

        <!-- TODO: replace with real Google reviews -->
        <div class="avis__card">
          <div class="avis__stars" aria-label="5 étoiles">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="avis__text">
            "Après des années avec une devanture vieillissante, j'ai enfin franchi le pas.
            Le résultat dépasse mes attentes. Professionnels, à l'écoute, et le rendu
            final est vraiment élégant."
          </p>
          <div class="avis__author">
            <div class="avis__avatar" aria-hidden="true">S</div>
            <div>
              <p class="avis__name">Sophie L.</p>
              <p class="avis__meta">Gérante — Pharmacie du Centre, Vincennes</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </section>

  <!-- FINAL CTA -->
  <section class="cta-final">

    <!-- Decorative ghost text -->
    <span class="cta-final__ghost" aria-hidden="true" style="font-size: 18rem;">FAÇADE</span>

    <div class="cta-final__grid">

      <!-- Left column -->
      <div class="cta-final__left">
        <div class="cta-final__label">
          <span class="cta-final__label-line"></span>
          <span class="cta-final__label-text">Prêt à transformer votre commerce ?</span>
        </div>
        <h2 class="cta-final__title">
          Votre façade mérite <em class="cta-final__em">mieux</em>
        </h2>
        <p class="cta-final__sub">
          Chaque jour sans une façade soignée est un client qui passe sans s'arrêter.
        </p>
      </div>

      <!-- Right column -->
      <div class="cta-final__right">
        <p class="cta-final__desc">
          Nous intervenons sur toute l'Île-de-France.
          Devis gratuit, réponse sous 24h, accompagnement de A à Z.
        </p>

        <div class="cta-final__buttons">
          <a href="tel:+33123456789" class="cta-final__btn-primary">Appeler maintenant</a>
          <!-- TODO: update with real email -->
          <a href="mailto:contact@lesenseignes.fr" class="cta-final__btn-ghost">Envoyer un message</a>
        </div>

        <div class="cta-final__trust">
          <span class="cta-final__trust-item">✓ Devis gratuit</span>
          <span class="cta-final__trust-sep"></span>
          <span class="cta-final__trust-item">✓ Réponse sous 24h</span>
          <span class="cta-final__trust-sep"></span>
          <span class="cta-final__trust-item">✓ Île-de-France</span>
        </div>
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__grid">

      <!-- Brand -->
      <div class="footer__brand">
        <p class="footer__logo">Les Enseignes</p>
        <p class="footer__tagline">Façades &amp; Signalétique depuis 2008</p>
      </div>

      <!-- Nav -->
      <nav class="footer__nav" aria-label="Footer navigation">
        <a href="#services" class="footer__nav-link">Services</a>
        <a href="#tarifs"   class="footer__nav-link">Tarifs</a>
        <a href="#avis"     class="footer__nav-link">Avis</a>
        <a href="tel:+33123456789" class="footer__nav-link">Contact</a>
      </nav>

      <!-- Legal -->
      <div class="footer__legal">
        <!-- TODO: update year dynamically -->
        <p class="footer__copy">© 2024 Les Enseignes</p>
        <!-- TODO: add real legal page -->
        <a href="#" class="footer__mentions">Mentions légales</a>
      </div>

    </div>
  </footer>

</Layout>

<style>
